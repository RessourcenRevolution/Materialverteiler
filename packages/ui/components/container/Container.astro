---
import type { HTMLAttributes } from "astro/types";

export interface Props extends HTMLAttributes<"div"> {
  size?: "sm" | "md" | "lg" | "xl";
  content?: string;
}
const sizes = {
  sm: "max-w-sm",
  md: "max-w-lg",
  lg: "max-w-2xl",
  xl: "max-w-4xl",
};
const { content, size, ...props } = Astro.props;
---

<div class:list={["mx-auto", size && sizes[size]]} {...props}>
  <slot>{content}</slot>
</div>
