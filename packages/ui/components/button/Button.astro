---
import type { HTMLAttributes } from "astro/types";

export type Props = HTMLAttributes<"a"> &
  HTMLAttributes<"button"> & {
    label: string;
    variant?: "primary" | "secondary";
  };

const {
  label,
  variant = "secondary",
  href,
  class: className,
  ...props
} = Astro.props;
const Element = href ? "a" : "button";
---

<Element
  href={href}
  class:list={[
    "inline-block",
    "px-3 py-2.5",
    " text-body text-base font-bold",
    "border-body border-(length:--border)",
    variant === "primary" && "bg-primary hover:bg-body hover:text-primary",
    variant === "secondary" && "text-body hover:text-white hover:bg-body",
    "cursor-pointer",
    "active:translate-y-px",
    className,
  ]}
  {...props}
>
  {label}
</Element>
