---
export interface Props {
  label: string;
  href?: string;
  outline?: boolean;
}
const { label, href, outline } = Astro.props;
const Element = href ? "a" : "button";
---

<Element
  href={href}
  class:list={[
    "inline-block",
    "px-3 py-2",
    " text-stone-900 rounded-sm",
    outline ? "ring hover:ring-2" : "bg-stone-200 hover:bg-stone-300",
    "cursor-pointer",
    " active:translate-y-px",
  ]}
>
  {label}
</Element>
