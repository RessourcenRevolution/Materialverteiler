---
export interface Props {
  label: string;
  href?: string;
}
const { label, href } = Astro.props;
const Element =  href ? 'a' : 'button'
---

<Element
  href={href}
  class:list={[
    "inline-block",
    "px-3 py-2",
    "bg-stone-200 text-stone-900 rounded-sm",
    "cursor-pointer",
    "hover:bg-stone-300 active:translate-y-px",
  ]}
>
  {label}
</Element>
