---
export interface Props {
  name: string;
  label?: string;
  value?: string;
  placeholder?: string;
  required?: boolean;
  rows?: number;
  error?: string;
}
const {
  label,
  value,
  name,
  placeholder,
  required,
  rows = "3",
  error,
} = Astro.props;
---

<div>
  {
    label && (
      <label for={name} class="block w-full mb-2 font-bold">
        {label}
      </label>
    )
  }
  <textarea
    name={name}
    placeholder={placeholder}
    required={required}
    class:list={[
      "w-full border border-stone-500 rounded-sm px-3 py-2",
      error && "border-red-800!",
    ]}
    rows={rows}>{value}</textarea
  >
  {error && <p class="text-red-800 text-sm">{error}</p>}
</div>
