---
export interface Props {
  id: string
  name: string
  label?: string
  value?: string
  required?: boolean
  rows?: number
  error?: string
}
const {
  id,
  label,
  value,
  name,
  required,
  rows = '4',
  error,
} = Astro.props;
---

<div class="relative">
  {
    label && (
      <label
        for={id}
        class:list={[
          'absolute font-bold text-body text-base leading-none start-[0.9em] pr-1',
          'transform scale-75 top-[0.85em] -translate-y-[0.5em] z-10 origin-left duration-200',
          'line-clamp-1',
          'has-[+textarea:focus]:scale-75! has-[+textarea:focus]:top-[0.85em]!',
          'has-[+textarea:placeholder-shown]:scale-100 has-[+textarea:placeholder-shown]:top-[1.65em]',
          'has-[+textarea:placeholder-shown]:pointer-events-none',
        ]}
      >
        {label}
      </label>
    )
  }
  <textarea
    id={id}
    name={name}
    placeholder=" "
    required={required}
    rows={rows}
    aria-invalid={!!error}
    aria-describedby={error ? `${id}-error` : undefined}
    class:list={[
      'w-full px-[0.75em] pb-[0.5em] pt-[1em]',
      'text-body text-base border-(length:--border) border-body rounded-xs',
      error && 'border-red-800!',
    ]}>{value}</textarea
  >
  {
    error && (
      <p
        id={`${id}-error`}
        class="text-red-800 text-sm">
        {error}
      </p>
    )
  }
</div>
