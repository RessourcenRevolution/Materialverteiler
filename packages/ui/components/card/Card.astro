---
export interface Props {
  border?: boolean;
  title?: string;
  content?: string;
}

const { title, content, border = true } = Astro.props;
---

<div class:list={["p-4", border && "border rounded-md"]}>
  {
    title && (
      <h2 class:list={["text-xl font-bold text-body", content && "mb-2"]}>
        {title}
      </h2>
    )
  }
  <slot>
    {content && <Fragment set:html={content} />}
  </slot>
</div>
