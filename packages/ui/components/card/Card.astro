---
export interface Props {
  content?: string;
  image?: string;
  class?: string;
  imageClass?: string;
  contentClass?: string;
}

const {
  content,
  image,
  class: className,
  imageClass,
  contentClass,
} = Astro.props;
---

<article class:list={["flex flex-col gap-4", className]}>
  {
    image && (
      <img
        src={image}
        class:list={["w-full aspect-4/3 object-cover rounded-xs", imageClass]}
      />
    )
  }
  <div class:list={["flex flex-col gap-2 px-6", contentClass]}>
    <slot>
      {content && <Fragment set:html={content} />}
    </slot>
  </div>
</article>
