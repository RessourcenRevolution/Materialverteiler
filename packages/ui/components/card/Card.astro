---
export interface Props {
  content?: string
  image?: string
  imageAlt?: string
  class?: string
  imageClass?: string
  contentClass?: string
}

const {
  content,
  image,
  imageAlt,
  class: className,
  imageClass,
  contentClass,
} = Astro.props;
---

<article class:list={['flex flex-col gap-4', className]}>
  {
    image
      ? (
          <img
            src={image}
            alt={imageAlt}
            class:list={['w-full aspect-4/3 object-cover rounded-xs', imageClass]}
          />
        )
      : (
          <div class:list={['w-full aspect-4/3 bg-stone-200 rounded-xs', imageClass]} />
        )
  }
  <div class:list={['flex flex-col gap-2 px-6', contentClass]}>
    <slot>
      {content && <Fragment set:html={content} />}
    </slot>
  </div>
</article>
