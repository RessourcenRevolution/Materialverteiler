---
export interface Props {
  id: string
  name: string
  options: Array<{ label: string, value: string }>
  label?: string
  value?: string
  required?: boolean
  error?: string
}
const {
  id,
  name,
  options,
  label,
  value,
  required,
  error,
} = Astro.props;
---

<div
  class="relative"
  style="--chevron: url('data:image/svg+xml,%3Csvg%20stroke-width%3D%221.5%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20color%3D%22%23000000%22%3E%3Cpath%20d%3D%22M6%209L12%2015L18%209%22%20stroke%3D%22%23000000%22%20stroke-width%3D%221.5%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3C%2Fpath%3E%3C%2Fsvg%3E')"
>
  <label
    for={id}
    class="block font-bold text-body text-base mb-1"
  >
    <slot>{label || ''}</slot>
  </label>
  <select
    id={id}
    name={name}
    value={value}
    required={required}
    aria-invalid={!!error}
    aria-describedby={error ? `${id}-error` : undefined}
    class="w-full text-body [&:has(option[value='']:checked)]:font-bold border-(length:--border) text-base border-body rounded-xs px-3 py-3 appearance-none bg-(image:--chevron) bg-no-repeat bg-[right_0.75rem_center] bg-size-[2rem]">
    {options.map(option =>
      <option value={option.value} selected={option.value === value}>
        {option.label}
      </option>)}
  </select>
  {
    error && (
      <p
        id={`${id}-error`}
        class="text-red-800 text-sm">
        {error}
      </p>
    )
  }
</div>
