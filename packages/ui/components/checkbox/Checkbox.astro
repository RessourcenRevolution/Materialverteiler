---
export interface Props {
  name: string;
  label?: string;
  value?: boolean;
  required?: boolean;
  error?: string;
}
const { label, value, name, required, error } = Astro.props;
---

<div class="relative flex" style="--checkbox: url('data:image/svg+xml,%3Csvg%20stroke-width%3D%223%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20color%3D%22%23000000%22%3E%3Cpath%20d%3D%22M5%2013L9%2017L19%207%22%20stroke%3D%22%23000000%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3C%2Fpath%3E%3C%2Fsvg%3E')">
  <label
    for={name}
    class:list={[
      "font-bold text-body text-base px-8",
      "before:absolute before:top-[min(1.5%,3px)] before:left-0 before:w-6 before:h-6 before:block before:z-10 before:border-(length:--border) before:border-body before:rounded-xs",
      "before:cursor-pointer",
      "has-[+input:checked]:before:bg-(image:--checkbox)"
    ]}
  >
    <slot>{label || ''}</slot>
  </label>
  <input
    type="checkbox"
    id={name}
    name={name}
    checked={value}
    required={required}
    class="absolute border-(length:--border) border-body rounded-xs opacity-0"
  />
  {error && <p class="text-red-800 text-sm">{error}</p>}
</div>
