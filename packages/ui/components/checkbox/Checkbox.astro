---
export interface Props {
  id: string;
  name: string;
  label?: string;
  checked?: boolean;
  value?: string;
  required?: boolean;
  class?: string;
  error?: string;
  background?: 'transparent' | 'white'
}
const {
  id,
  label,
  checked = false,
  value,
  name,
  required,
  class: className,
  error,
  background = 'transparent'
} = Astro.props;
---

<div
  class:list={["relative", className]}
  style="--checkbox: url('data:image/svg+xml,%3Csvg%20stroke-width%3D%223%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20color%3D%22%23000000%22%3E%3Cpath%20d%3D%22M5%2013L9%2017L19%207%22%20stroke%3D%22%23000000%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3C%2Fpath%3E%3C%2Fsvg%3E')"
>
  <div class="flex">
    <label
      for={id}
      class:list={[
        "font-bold text-body text-base",
        "before:absolute before:top-[min(1.5%,3px)] before:left-0 before:w-6 before:h-6 before:block before:z-10 before:border-(length:--border) before:border-body before:rounded-xs",
        "before:cursor-pointer",
        "has-[+input:checked]:before:bg-(image:--checkbox)",
        label || Astro.slots.has('default') ? "px-8" : "px-3",
        background === 'white' ? 'before:bg-white' : ''
      ]}
    >
      <slot>{label || ""}</slot>
    </label>
    <input
      type="checkbox"
      id={id}
      name={name}
      checked={checked}
      value={value}
      required={required}
      class="absolute border-(length:--border) border-body rounded-xs opacity-0"
    />
  </div>
  {error && <p class="text-red-800 text-sm">{error}</p>}
</div>
