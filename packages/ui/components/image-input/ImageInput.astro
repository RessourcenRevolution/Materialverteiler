---
export interface Props {
  name: string;
  label?: string;
  error?: string;
}
const { label, name, error } = Astro.props;
---

<div>
  {
    label && (
      <label for={name} class="block w-full mb-2 font-bold text-body text-base">
        {label}
      </label>
    )
  }
  <image-uploader name="images"></image-uploader>
  {error && <p class="text-red-800 text-sm">{error}</p>}
</div>

<script src="@rr/image-uploader"></script>

<style>
  @reference "../../tailwind.css";
  image-uploader::part(button) {
    @apply text-base border-0 inline-block px-3 py-2 text-body rounded-sm bg-stone-200 cursor-pointer;
  }
  image-uploader::part(button):hover {
    @apply bg-stone-300;
  }
</style>
