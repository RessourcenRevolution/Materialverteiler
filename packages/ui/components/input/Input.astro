---
export interface Props {
  name: string;
  label?: string;
  value?: string;
  type?: astroHTML.JSX.HTMLInputTypeAttribute;
  required?: boolean;
  error?: string;
}
const { label, value, name, type, required, error } = Astro.props;
---

<div class="relative">
  {
    label && (
      <label
        for={name}
        class:list={[
          "absolute font-bold text-body text-base leading-none start-[0.9em]",
          "transform scale-75 top-[0.85em] -translate-y-[0.5em] z-10 origin-left duration-200",
          "has-[+input:focus]:scale-75! has-[+input:focus]:top-[0.85em]!",
          "has-[+input:placeholder-shown]:scale-100 has-[+input:placeholder-shown]:top-[1.65em]",
          "has-[+input:placeholder-shown]:pointer-events-none",
        ]}
      >
        {label}
      </label>
    )
  }
  <input
    name={name}
    type={type}
    value={value}
    placeholder={" "}
    required={required}
    class:list={[
      "peer w-full text-body border-(length:--border) text-base border-body px-[0.75em] pb-[0.5em] pt-[1em]",
      error && "border-red-800!",
    ]}
  />
  {error && <p class="text-red-800 text-sm">{error}</p>}
</div>
