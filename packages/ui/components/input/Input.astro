---
export interface Props {
  name: string;
  label?: string;
  value?: string;
  placeholder?: string;
  type?: astroHTML.JSX.HTMLInputTypeAttribute;
  required?: boolean;
}
const { label, value, name, placeholder, type, required } = Astro.props;
---

<div>
  {
    label && (
      <label for={name} class="block w-full mb-2 font-bold">
        {label}
      </label>
    )
  }
  <input
    name={name}
    type={type}
    value={value}
    placeholder={placeholder}
    required={required}
    class="w-full border border-stone-500 rounded-sm px-3 py-2"
  />
</div>
