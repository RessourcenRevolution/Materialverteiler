---
import type { HTMLAttributes } from 'astro/types'

export type Props = HTMLAttributes<'a'> & {
  class?: string
}

const { href, class: className, ...props } = Astro.props;
---

<a
  href={href}
  class:list={[
    'text-body text-base font-bold underline decoration-2 underline-offset-4 hover:no-underline',
    className,
  ]}
  {...props}
>
  <slot />
</a>
