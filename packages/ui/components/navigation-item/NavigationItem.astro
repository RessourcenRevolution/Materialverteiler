---
import type { HTMLAttributes } from "astro/types";

export type Props = HTMLAttributes<"a"> & HTMLAttributes<"button">;

const { href, class: className, ...props } = Astro.props;

const Element = href ? "a" : "button";
---

<Element
  href={href}
  class:list={[
    "flex items-center gap-2",
    "text-body text-base font-bold underline decoration-2 underline-offset-4 hover:no-underline",
    className,
  ]}
  {...props}
>
  <slot>Item</slot>
</Element>
