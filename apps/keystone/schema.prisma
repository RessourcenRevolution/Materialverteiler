// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource sqlite {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  name      String    @default("")
  email     String    @unique @default("")
  password  String
  createdAt DateTime? @default(now())
}

model Image {
  id              String  @id @default(cuid())
  name            String  @default("")
  altText         String  @default("")
  image_id        String?
  image_filesize  Int?
  image_width     Int?
  image_height    Int?
  image_extension String?
}

model Page {
  id               String  @id @default(cuid())
  title            String  @default("")
  slug             String  @default("")
  parent           Page?   @relation("Page_parent", fields: [parentId], references: [id])
  parentId         String? @map("parent")
  path             String  @unique @default("")
  access           String  @default("public")
  content          String  @default("[{\"type\":\"paragraph\",\"children\":[{\"text\":\"\"}]}]")
  from_Page_parent Page[]  @relation("Page_parent")

  @@index([parentId])
}

model NavigationItem {
  id                    String       @id @default(cuid())
  icon                  String?
  title                 String       @default("")
  path                  String       @default("")
  from_Navigation_items Navigation[] @relation("Navigation_items")
  from_Footer_links     Footer[]     @relation("Footer_links")
}

model Navigation {
  id    String           @id @default(cuid())
  name  String           @unique
  items NavigationItem[] @relation("Navigation_items")
}

model Footer {
  id      Int              @id
  content String           @default("[{\"type\":\"paragraph\",\"children\":[{\"text\":\"\"}]}]")
  links   NavigationItem[] @relation("Footer_links")
}

model Person {
  id              String  @id @default(cuid())
  name            String  @default("")
  description     String  @default("")
  photo_id        String?
  photo_filesize  Int?
  photo_width     Int?
  photo_height    Int?
  photo_extension String?
}
