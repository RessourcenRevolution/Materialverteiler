---
import { Picture } from 'astro:assets'

const { image } = Astro.props
const columns = Astro.locals.columns || 1;
---

<Picture
  data-module
  src={image?.data?.image?.url}
  width={image?.data?.image?.width}
  height={image?.data?.image?.height}
  layout="constrained"
  formats={['avif', 'webp']}
  sizes={`${Math.ceil(100 / columns)}vw`}
  alt={image?.data?.altText || ''}
  class:list={[
    'w-[calc(100%+(var(--body-inline-padding)*2))] md:w-full',
    '-mx-(--body-inline-padding) md:mx-0',
    'max-w-none md:max-w-full',
    'md:rounded-xs',
  ]}
  pictureAttributes={{ class: 'm-0!' }}
/>
