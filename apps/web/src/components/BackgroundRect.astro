---
interface Props {
  variant: 'page' | 'custom'
  color?: 'yellow' | 'purple'
  class?: string
}

const { variant, color = 'yellow', class: className } = Astro.props

const variants = {
  page: '-left-12 -top-12 w-[calc(90%+var(--spacing)*12)] md:w-[calc(70%+var(--spacing)*12)] h-[82%]',
  custom: '',
}
const colors = {
  yellow: 'bg-[#ffff82]',
  purple: 'bg-[#d2d5dd]',
}
---
<div class:list={['absolute -z-1 animate-open-from-left', variants[variant], colors[color], className]} />
