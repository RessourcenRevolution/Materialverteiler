---
import { actions } from 'astro:actions'
import { type User } from '~/schemas/user'
import { useTranslations } from '~/i18n/ui'
import { Button, Alert } from '@rr/ui/components'

interface Props {
  class?: string
}

const { class: className } = Astro.props

const t = useTranslations()

const user = Astro.locals.pb.authStore.record as unknown as User

const result = Astro.getActionResult(actions.sendEmailVerification);
---

{
  result?.error
    ? (
        <Alert
          variant="error"
          text={t('confirm-email.resend.error')}
          class:list={['mb-4', className]}
        />
      )
    : result?.data
      ? (
          <Alert
            variant="success"
            text={t('confirm-email.resend.success')}
            class:list={['mb-4', className]}
          />
        )
      : (
          !user.verified && (
            <Alert
              variant="warning"
              class:list={['flex justify-between items-center flex-wrap md:flex-nowrap gap-y-4 gap-x-8 mb-12', className]}
            >
              <p class="text-base">{t('confirm-email.warning.text')}</p>
              <form method="POST" action={actions.sendEmailVerification} class="-m-1 flex-shrink-0">
                <Button label={t('confirm-email.warning.button')} />
              </form>
            </Alert>
          )
        )
}
