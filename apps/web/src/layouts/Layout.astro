---
import Header from '~/components/Header/Header.astro'
import '~/styles/global.css'
import { APP_NAME } from 'astro:env/client'
import { defaultLang } from '~/i18n/ui'
import { fetchNavigations } from '~/keystone'
import Footer from '~/components/Footer.astro'

const { mainNavigation, metaNavigation } = await fetchNavigations()
---

<!doctype html>
<html lang={defaultLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{APP_NAME}</title>
  </head>
  <body class="h-auto! min-h-full grid grid-rows-[auto_1fr_auto] bg-background">
    <Header mainNavigation={mainNavigation} metaNavigation={metaNavigation} class="max-w-[1600px] mx-auto" />
    <main class="w-full max-w-[1600px] mx-auto px-(--body-inline-padding)">
      <slot />
    </main>
    <Footer class="max-w-6xl mx-auto" />
    <script src="~/scripts/main.ts"></script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
