---
import { Container } from '@rr/ui/components'
import { DocumentRenderer } from 'astro-document-renderer'
import Layout from '~/layouts/Layout.astro'
import Image from '~/components/keystone/Image.astro'

export const prerender = false

const { path } = Astro.params

if (!process.env.KEYSTONE_GRAPHQL_ENDPOINT) {
  throw new Error('KEYSTONE_GRAPHQL_ENDPOINT environment variable is not set')
}

const response = await fetch(process.env.KEYSTONE_GRAPHQL_ENDPOINT, {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    query: `
      query Page($where: PageWhereUniqueInput!) {
        page(where: $where) {
          title
          content {
            document(hydrateRelationships: true)
          }
        }
      }
      `,
    variables: {
      where: {
        path: `/${path || ''}`,
      },
    },
  }),
})
const result = await response.json()
const page = result?.data?.page

if (!page) {
  return new Response(null, { status: 404 })
}
---

<Layout>
  <Container size="lg" class="prose">
    <DocumentRenderer
      document={page.content.document}
      componentBlocks={{ image: Image }}
    />
  </Container>
</Layout>
