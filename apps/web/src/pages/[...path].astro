---
import { Container } from '@rr/ui/components'
import { DocumentRenderer } from 'astro-document-renderer'
import Layout from '~/layouts/Layout.astro'
import Columns from '~/components/keystone/Columns.astro'
import Image from '~/components/keystone/Image.astro'
import Text from '~/components/keystone/Text.astro'
import Button from '~/components/keystone/Button.astro'

interface Page {
  title: string
  path: string
  content: { document: any }
}

export const prerender = false

const { path } = Astro.params

if (!process.env.KEYSTONE_GRAPHQL_ENDPOINT) {
  throw new Error('KEYSTONE_GRAPHQL_ENDPOINT environment variable is not set')
}

const response = await fetch(process.env.KEYSTONE_GRAPHQL_ENDPOINT, {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    query: `
      query Page($where: PageWhereUniqueInput!) {
        page(where: $where) {
          title
          content {
            document(hydrateRelationships: true)
          }
        }
      }
      `,
    variables: {
      where: {
        path: `/${path || ''}`,
      },
    },
  }),
})

const result = await response.json()
const page = result?.data?.page as Page

if (!page) {
  return new Response(null, { status: 404 })
}
---

<Layout>
  <Container size="xl" class="prose page-animation [&>[data-module]]:my-12 md:[&>[data-module]]:my-24 [&>[data-module]:first-child]:mt-0">
    <DocumentRenderer
      document={page.content.document}
      renderers={{
        block: { layout: Columns },
      }}
      componentBlocks={{ image: Image, text: Text, button: Button }}
    />
  </Container>
</Layout>
