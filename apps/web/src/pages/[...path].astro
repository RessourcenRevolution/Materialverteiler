---
import { Container } from '@rr/ui/components'
import { DocumentRenderer } from 'astro-document-renderer'
import { fetchPage } from '~/keystone'
import Layout from '~/layouts/Layout.astro'
import Columns from '~/components/keystone/Columns.astro'
import Image from '~/components/keystone/Image.astro'
import Text from '~/components/keystone/Text.astro'
import Button from '~/components/keystone/Button.astro'
import Listings from '~/components/keystone/Listings.astro'

export const prerender = false

const { path } = Astro.params

const { page } = await fetchPage(path)

if (!page || page.access !== 'public') {
  return new Response(null, { status: 404 })
}
---

<Layout>
  <Container
    size="xl"
    class:list={[
      'prose page-animation',
      '[&>[data-module]]:my-12 md:[&>[data-module]]:my-24 [&>[data-module]:first-child]:mt-0',
    ]}
  >
    <DocumentRenderer
      document={page.content.document}
      renderers={{
        block: { layout: Columns },
      }}
      componentBlocks={{
        image: Image,
        text: Text,
        button: Button,
        listings: Listings,
      }}
    />
  </Container>
</Layout>
