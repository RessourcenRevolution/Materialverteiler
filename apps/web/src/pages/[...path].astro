---
import { Container } from '@rr/ui/components'
import { DocumentRenderer } from 'astro-document-renderer'
import Layout from '~/layouts/Layout.astro'
import Image from '~/components/keystone/Image.astro'
import type { GetStaticPaths } from 'astro'

interface Page {
  title: string
  path: string
  content: { document: any }
}

interface Props {
  page: Page
}

export const prerender = true

export const getStaticPaths = (async () => {
  if (!process.env.KEYSTONE_GRAPHQL_ENDPOINT) {
    throw new Error('KEYSTONE_GRAPHQL_ENDPOINT environment variable is not set')
  }
  const response = await fetch(process.env.KEYSTONE_GRAPHQL_ENDPOINT, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
      query Pages {
        pages {
          path
          title
          content {
            document(hydrateRelationships: true)
          }
        }
      }
      `,
    }),
  })

  const result = await response.json()
  const pages = result?.data?.pages as Page[]
  return pages.map(page => ({
    params: { path: page.path },
    props: { page },
  }))
}) satisfies GetStaticPaths

const { page } = Astro.props

if (!page) {
  return new Response(null, { status: 404 })
}
---

<Layout>
  <Container size="lg" class="prose">
    <DocumentRenderer
      document={page.content.document}
      componentBlocks={{ image: Image }}
    />
  </Container>
</Layout>
