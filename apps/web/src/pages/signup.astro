---
import Layout from "~/layouts/Layout.astro";
import { Input, Button, Alert } from "@rr/ui/components";
import { usePocketbase } from "@rr/astro-pocketbase/scripts";
import { useTranslations } from "~/i18n/ui";

export const prerender = false;

const t = useTranslations();
const { signup } = usePocketbase(Astro.locals.pb);

let error = "";
let name = "";
let email = "";
let password = "";

if (Astro.request.method === "POST") {
  const body = await Astro.request.formData();
  name = body.get("name") as string;
  email = body.get("email") as string;
  password = body.get("password") as string;

  const {
    status,
    success,
    error: _error,
  } = await signup({
    name,
    email,
    password,
  });
  if (success) {
    return new Response(null, {
      status: 302,
      headers: {
        Location: "/dashboard",
        "Set-Cookie": Astro.locals.pb.authStore.exportToCookie({
          secure: import.meta.env.DEV ? false : true,
        }),
      },
    });
  }
  error = _error;
  Astro.response.status = status;
}
---

<Layout>
  <div class="mx-auto max-w-lg">
    <h1 class="text-2xl font-bold mb-6">
      {t("signup.title")}
    </h1>
    <form class="flex flex-col gap-6" method="post">
      <Input name="name" type="text" label="Name" value={name} required />
      <Input
        name="email"
        type="email"
        label={t("forms.email")}
        value={email}
        required
      />
      <Input
        name="password"
        type="password"
        label={t("forms.password")}
        value={password}
        required
      />
      {error && <Alert variant="error" text={error} />}
      <Button label={t("signup.button")} />
    </form>
  </div>
</Layout>
