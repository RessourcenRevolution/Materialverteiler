---
import { Container } from "@rr/ui/components";
import ListingList from "~/components/ListingList.astro";
import { useTranslations } from "~/i18n/ui";
import Layout from "~/layouts/Layout.astro";
import { ListingSchema, type Listing } from "~/schemas/listing";
import { UserSchema, type User } from "~/schemas/user";

export const prerender = false;

const t = useTranslations();

if (!Astro.locals.pb.authStore.record?.id) {
  Astro.redirect("/logout");
  return;
}

const record = await Astro.locals.pb
  .collection("users")
  .getOne(Astro.locals.pb.authStore.record?.id, { expand: "team" });
const user = UserSchema.parse(record) as User;

const items = await Astro.locals.pb.collection("listings").getFullList({
  filter: Astro.locals.pb.filter("user = {:user}", { user: user.id }),
  expand: "user,user.team",
});
const listings = ListingSchema.array().parse(items) as Listing[];
---

<Layout>
  <Container size="xl">
    <h1 class="text-3xl font-bold text-heading mb-4">
      {t("profile.title")}
    </h1>
    <p class="mb-12">
      {t("profile.name")}:
      {user.firstname}
      {user.lastname}<br />
      {t("profile.email")}: {user.email}<br />
      {t("profile.team")}: {user.expand?.team?.name}<br />
    </p>

    <h2 class="text-2xl font-bold text-heading mb-4">
      {t("profile.active-listings")}
    </h2>
    <ListingList listings={listings} edit={true} />
  </Container>
</Layout>
