---
import { Container } from "@rr/ui/components";
import { useTranslations } from "~/i18n/ui";
import Layout from "~/layouts/Layout.astro";
import { UserSchema, type User } from "~/schemas/user";

export const prerender = false;

const t = useTranslations();

if (!Astro.locals.pb.authStore.record?.id) {
  Astro.redirect("/logout");
  return;
}

const record = await Astro.locals.pb
  .collection("users")
  .getOne(Astro.locals.pb.authStore.record?.id, { expand: "team" });
const user = UserSchema.parse(record) as User;
---

<Layout>
  <Container size="xl">
    <h1 class="text-2xl font-bold mb-4">
      {t("profile.title")}
    </h1>
    <p>
      {t("profile.name")}:
      {user.firstname}
      {user.lastname}<br />
      {t("profile.email")}: {user.email}<br />
      {t("profile.team")}: {user.expand?.team?.name}<br />
    </p>
  </Container>
</Layout>
