---
import { Container } from "@rr/ui/components";
import { useTranslations } from "~/i18n/ui";
import Layout from "~/layouts/Layout.astro";

export const prerender = false;

const t = useTranslations();

if (!Astro.locals.pb.authStore.record?.id) {
  Astro.redirect("/logout");
  return;
}

const user = await Astro.locals.pb
  .collection("users")
  .getOne(Astro.locals.pb.authStore.record?.id);
---

<Layout>
  <Container size="xl">
    <h1 class="text-2xl font-bold mb-4">
      {t("profile.title")}
    </h1>
    <p>
      {t("profile.name")}: {user.name}<br />
      {t("profile.email")}: {user.email}<br />
    </p>
  </Container>
</Layout>
