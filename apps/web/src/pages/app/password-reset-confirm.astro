---
import Layout from '~/layouts/Layout.astro'
import { Input, Button, Alert, Heading, Link } from '@rr/ui/components'
import { useTranslations, type TranslationKey } from '~/i18n/ui'
import { actions } from 'astro:actions'
import { isInputError } from 'astro:actions'
import { fieldError } from '~/forms'
import BackgroundRect from '~/components/BackgroundRect.astro'

export const prerender = false

const t = useTranslations()

const result = Astro.getActionResult(actions.confirmPasswordReset)
const data = Astro.request.method === 'POST' ? await Astro.request.formData() : null

// If already logged in, redirect to dashboard
if (Astro.locals.pb.authStore.isValid) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/app/listings',
    },
  })
}

// Get token from URL query parameters
const url = new URL(Astro.request.url)
const token = url.searchParams.get('token')

// If no token, show error
if (!result?.data?.success && !token && !data?.get('token')) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/app/password-reset?error=invalid_token',
    },
  })
}
---

<Layout>
  <div class="mx-auto max-w-lg relative">
    <BackgroundRect variant="page" class="animate-delay-400" />
    <Heading tag="h1" size="xl" class="mb-6 animate-slide-in">
      {t('password-reset-confirm.title')}
    </Heading>

    {!result?.data?.success
      ? (
          <>
            <p class="mb-6 text-gray-600 animate-slide-in animate-delay-100">
              {t('password-reset-confirm.description')}
            </p>
            <form id="password-reset-confirm-form" class="flex flex-col gap-6" method="post" action={actions.confirmPasswordReset}>
              <input type="hidden" name="token" value={data?.get('token') as string || token} />

              <Input
                id="password"
                name="password"
                type="password"
                label={t('password-reset-confirm.password')}
                value={data?.get('password') as string}
                error={fieldError('password', result?.error, 'password-reset-confirm.errors.')}
                class="animate-slide-in animate-delay-200"
              />

              <Input
                id="passwordConfirm"
                name="passwordConfirm"
                type="password"
                label={t('password-reset-confirm.password-confirm')}
                value={data?.get('passwordConfirm') as string}
                error={fieldError('passwordConfirm', result?.error, 'password-reset-confirm.errors.')}
                class="animate-slide-in animate-delay-300"
              />

              {result?.error && !isInputError(result.error) && (
                <Alert
                  variant="error"
                  text={t(
                    ('password-reset-confirm.errors.' + result.error.message) as TranslationKey,
                  )}
                />
              )}

              <div class="flex gap-4 items-center animate-slide-in animate-delay-400">
                <Button
                  label={t('password-reset-confirm.button')}
                  variant="primary"
                  class="self-start animate-slide-in animate-delay-400"
                />
                <Link href="/app/login" class="ml-auto">
                  {t('header.login')}
                </Link>
              </div>

            </form>
          </>
        )
      : (
          <div class="flex flex-col gap-6 animate-slide-in animate-delay-200">
            <Alert
              variant="success"
              text={t('password-reset-confirm.success')}
            />
            <Button
              label={t('header.login')}
              href="/app/login"
              variant="primary"
              class="self-start"
            />
          </div>
        )}
  </div>
</Layout>

