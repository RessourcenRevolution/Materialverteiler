---
import { Alert, Button, Checkbox, Container, Heading } from '@rr/ui/components'
import { actions } from 'astro:actions'
import ListingList from '~/components/ListingList.astro'
import { defaultLang, ui, useTranslations } from '~/i18n/ui'
import Layout from '~/layouts/Layout.astro'
import { ListingSchema, type Listing } from '~/schemas/listing'
import { UserSchema, type User } from '~/schemas/user'
import Lock from 'iconoir/icons/lock.svg'

export const prerender = false

const t = useTranslations()

if (!Astro.locals.pb.authStore.record?.id) {
  Astro.redirect('/app/logout')
  return
}

const userAction = Astro.getActionResult(actions.user)
if (!userAction?.error && userAction?.data) {
  return Astro.redirect('/app/profile?success=profile', 302)
}

const removeListingAction = Astro.getActionResult(actions.removeListing)
if (!removeListingAction?.error && removeListingAction?.data) {
  return Astro.redirect('/app/profile?success=remove', 302)
}

const record = await Astro.locals.pb
  .collection('users')
  .getOne(Astro.locals.pb.authStore.record?.id, { expand: 'team' })
const user = UserSchema.parse(record) as User

const active = await Astro.locals.pb.collection('listings').getFullList({
  filter: Astro.locals.pb.filter('user = {:user} && (status = "new" || status = "open" || status = "reserved")', { user: user.id }),
  sort: 'start_date',
  expand: 'user,team',
})
const activeListings = ListingSchema.array().parse(active) as Listing[]

const past = await Astro.locals.pb.collection('listings').getFullList({
  filter: Astro.locals.pb.filter('user = {:user} && (status = "success" || status = "failure")', { user: user.id }),
  sort: 'start_date',
  expand: 'user,team',
})
const pastListings = ListingSchema.array().parse(past) as Listing[]

const success = Astro.url.searchParams.get('success')
---

<Layout>
  <Container size="xl">
    {success && success === 'profile'
      && <Alert variant="success" class="mb-12">
        {t('profile.success.profile')}
      </Alert>
    }
    {success && success === 'remove'
      && <Alert variant="success" class="mb-12">
        {t('profile.success.remove')}
      </Alert>
    }
    {removeListingAction?.error
      && <Alert variant="error" class="mb-12">
        {t('profile.error.remove')}
      </Alert>
    }
    <div class="flex gap-6 items-center mb-4">
      <Heading tag="h1" size="xl" class="">
        {t('profile.title')}
        {user.roles.includes('manager') && <span> (Manager)</span>}
      </Heading>
      {user.roles.includes('manager') && <Button size="sm" href="/app/manage" label={t('profile.management_settings')} icon={Lock} />}
    </div>
    <table class="[&_td]:px-2 [&_td:first-child]:pl-0 text-body mb-4">
      <tr>
        <td>{t('profile.name')}</td>
        <td>{user.firstname} {user.lastname}</td>
      </tr>
      <tr>
        <td>{t('profile.email')}</td>
        <td>{user.email}</td>
      </tr>
    </table>
    <p class="text-body">
      <strong>{t('profile.team')}</strong><br />
    </p>
    <table class="[&_td]:px-2 [&_td:first-child]:pl-0 text-body mb-4">
      <tr>
        <td>Name</td>
        <td>{user.expand?.team?.name}</td>
      </tr>
      <tr>
        <td>Art</td>
        <td>{t(`team-type.${user.expand?.team?.type}` as keyof (typeof ui)[typeof defaultLang])}</td>
      </tr>
      <tr>
        <td>Stadt</td>
        <td>{user.expand?.team?.city}</td>
      </tr>
    </table>
    <p class="mb-18">
      <Button size="sm" href="/app/logout" label={t('profile.logout')} />
    </p>

    <Heading tag="h2" size="lg" class="mb-4">
      {t('profile.notifications.title')}
    </Heading>
    <div class="mb-18">
      <p class="text-body mb-4">{t('profile.notifications.text')}</p>
      <form class="flex flex-col gap-4" method="post" action={actions.user}>
        <Checkbox id="notifications-new-listing" name="notifications" label={t('profile.notifications.new-listing')} value="new-listing" checked={user.notifications.includes('new-listing')} />
        <!-- <Checkbox id="notifications-newsletter" name="notifications" label="Newsletter" value="newsletter" checked={user.notifications.includes('newsletter')} /> -->
        <Button type="submit" size="sm" label={t('profile.notifications.save')} class="self-start" />
      </form>
    </div>

    <Heading tag="h2" size="lg" class="mb-4">
      {t('profile.active-listings')}
    </Heading>
    {
      activeListings && activeListings.length > 0
        ? <ListingList listings={activeListings} edit={true} class="mb-18" />
        : <p class="text-body italic mb-18">{t('profile.active-listings.none')}</p>
    }

    <Heading tag="h2" size="lg" class="mb-4">
      {t('profile.past-listings')}
    </Heading>
    {
      pastListings && pastListings.length > 0
        ? <ListingList listings={pastListings} edit={true} class="mb-12" />
        : <p class="text-body mb-12 italic">{t('profile.past-listings.none')}</p>
    }

  </Container>
</Layout>
