---
import Layout from '~/layouts/Layout.astro'
import { Input, Button, Alert, Heading, Link } from '@rr/ui/components'
import { useTranslations, type TranslationKey } from '~/i18n/ui'
import { actions } from 'astro:actions'
import { isInputError } from 'astro:actions'
import { fieldError } from '~/forms'
import BackgroundRect from '~/components/BackgroundRect.astro'

export const prerender = false

const t = useTranslations()

const result = Astro.getActionResult(actions.requestPasswordReset)
const data = Astro.request.method === 'POST' ? await Astro.request.formData() : null

// If already logged in, redirect to dashboard
if (Astro.locals.pb.authStore.isValid) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/app/listings',
    },
  })
}

// Get error from URL query parameters
const url = new URL(Astro.request.url)
const error = url.searchParams.get('error')

// Map of error codes to translation keys
const errorMessages: Record<string, TranslationKey> = {
  invalid_token: 'password-reset.errors.invalid_token',
}
---

<Layout>
  <div class="mx-auto max-w-lg relative">
    <BackgroundRect variant="page" class="animate-delay-400" />
    <Heading tag="h1" size="xl" class="mb-6 animate-slide-in">
      {t('password-reset.title')}
    </Heading>
    <p class="mb-6 text-gray-600 animate-slide-in animate-delay-100">
      {t('password-reset.description')}
    </p>

    {error && (
      <Alert
        variant="error"
        text={t(errorMessages[error] as TranslationKey || 'password-reset.errors.unknown_error')}
        class="mb-6 animate-slide-in animate-delay-200"
      />
    )}

    {!result?.data?.success
      ? (
          <form class="flex flex-col gap-6" method="post" action={actions.requestPasswordReset}>
            <Input
              name="email"
              type="email"
              label={t('forms.email')}
              value={data?.get('email') as string}
              error={fieldError('email', result?.error)}
              class="animate-slide-in animate-delay-200"
              required
            />

            {result?.error && !isInputError(result.error) && (
              <Alert
                variant="error"
                text={t(
                  ('password-reset.errors.' + result.error.message) as TranslationKey,
                )}
              />
            )}

            <div class="flex gap-4 items-center animate-slide-in animate-delay-300">
              <Button
                label={t('password-reset.button')}
                variant="primary"
                class="self-start animate-slide-in animate-delay-300"
              />
              <Link href="/app/login" class="ml-auto">
                {t('password-reset.login')}
              </Link>
            </div>

          </form>
        )
      : (
          <div class="flex flex-col gap-6 animate-slide-in animate-delay-200">
            <Alert
              variant="success"
              text={t('password-reset.success')}
            />
            <Button
              label={t('header.login')}
              href="/app/login"
              variant="primary"
              class="self-start"
            />
          </div>
        )}
  </div>
</Layout>
