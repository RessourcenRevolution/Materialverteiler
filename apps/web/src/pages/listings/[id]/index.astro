---
import Layout from '~/layouts/Layout.astro'
import { type Listing, ListingSchema } from '~/schemas/listing'
import { Container, Heading } from '@rr/ui/components'
import { useTranslations } from '~/i18n/ui'
import DateText from '~/components/DateText.astro'
import LocationText from '~/components/LocationText.astro'
import ContactForm from '~/components/ContactForm.astro'
import BackgroundRect from '~/components/BackgroundRect.astro'
import ListingUserStatus from '~/components/ListingUserStatus.astro'
import ImageGallery from '~/components/ImageGallery.astro'
import { ClientResponseError } from 'pocketbase'

export const prerender = false

const t = useTranslations()

const { id } = Astro.params
if (!id) {
  return new Response(null, { status: 404 })
}

const user = Astro.locals.pb.authStore.record!

// Get listing
let item
try {
  item = await Astro.locals.pb
    .collection('listings')
    .getOne(id)
}
catch (err) {
  if (err instanceof ClientResponseError && err.status === 404) {
    return Astro.rewrite('/listings/404')
  }
  return Astro.rewrite('/404')
}

if (!item) {
  return Astro.rewrite('/listings/404')
}

const listing = ListingSchema.parse(item) as Listing

---

<Layout>
  <Container size="xl" class="md:grid md:grid-cols-[2fr_1fr] gap-12">
    <div>
      <!-- User listing status -->
      {listing.user === user?.id && <ListingUserStatus listing={listing} />}

      <!-- Image Gallery -->
      <ImageGallery collection="listings" id={listing.id} images={listing.images} />

      <!-- Listing content -->
      <Heading tag="h1" size="md" class="mb-3">
        {listing.title}
      </Heading>
      <div class="md:hidden flex flex-wrap gap-x-8 gap-y-3 mb-6">
        <LocationText text={listing.postalcode + ' ' + listing.city} />
        <DateText
          text="Verfügbar ab"
          from={listing.start_date}
          to={listing.end_date ? listing.end_date : undefined}
        />
      </div>
      <p class="font-bold text-body mb-6 whitespace-pre-line">
        {listing.description}
      </p>
      {
        listing.material && (
          <>
            <h3 class="font-bold text-heading">
              {t('listing-page.material')}
            </h3>
            <p class="text-body mb-4">{listing.material}</p>
          </>
        )
      }
      {
        listing.measurements && (
          <>
            <h3 class="font-bold text-heading">
              {t('listing-page.measurements')}
            </h3>
            <p class="text-body mb-4">{listing.measurements}</p>
          </>
        )
      }
      {
        listing.condition && (
          <>
            <h3 class="font-bold text-heading">
              {t('listing-page.condition')}
            </h3>
            <p class="text-body mb-4">{listing.condition}</p>
          </>
        )
      }
      {
        listing.pickup_description && (
          <>
            <h3 class="font-bold text-heading">
              {t('listing-page.pickup_description')}
            </h3>
            <p class="text-body mb-4">{listing.pickup_description}</p>
          </>
        )
      }
      {
        listing.address && (
          <div class="md:hidden">
            <h3 class="font-bold text-heading">
              {t('listing-page.address')}
            </h3>
            <p class="text-body mb-4">
              {listing.address}, {listing.postalcode} {listing.city}
            </p>
          </div>
        )
      }

      <!-- Contact form -->
      {(listing.status === 'open' || listing.status === 'reserved')
        && <ContactForm listing={listing} class="mt-12" />
      }
    </div>

    <!-- Sidebar (desktop) -->
    <div class="hidden md:block">
      <div class="sticky top-[86px] py-6 rounded-xs -z-1">
        <BackgroundRect variant="custom" class="w-[66%] h-[calc(100%+1rem)]! -left-6 top-0" />
        <LocationText text={listing.postalcode + ' ' + listing.city} class="mb-4" />
        <DateText
          text="Verfügbar ab"
          from={listing.start_date}
          to={listing.end_date ? listing.end_date : undefined}
          class="items-start mb-4"
        />
        {listing.address
          && <>
            <h3 class="font-bold text-heading">
              {t('listing-page.address')}
            </h3>
            <p class="text-body">
              {listing.address}, {listing.postalcode}
              {listing.city}
            </p>
          </>
        }
      </div>
    </div>
  </Container>
</Layout>
