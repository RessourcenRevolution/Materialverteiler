---
import Layout from "~/layouts/Layout.astro";
import { type Listing, ListingSchema } from "~/schemas/listing";
import { Card, Button } from "@rr/ui/components";
import EmailVerificationWarning from "~/components/EmailVerificationWarning/EmailVerificationWarning.astro";
import { defaultLang } from "~/i18n/ui";

export const prerender = false;

const items = await Astro.locals.pb
  .collection("listings")
  .getFullList({ expand: "user" });
const listings = ListingSchema.array().parse(items) as Listing[];
---

<Layout>
  <EmailVerificationWarning />
  <h1 class="text-2xl font-bold mb-4">Dashboard</h1>
  <Button label="New listing" href="/listings/new" class="mb-4" />
  <div class="grid grid-cols-3 gap-4">
    {
      listings.map((listing) => (
        <Card title={listing.title} border>
          <div class="flex flex-col gap-2 mt-2">
            <p class="text-stone-500">
              @{listing.expand?.user?.name} -{" "}
              {new Date(listing.created).toLocaleDateString(defaultLang)}
            </p>
            <p class="text-stone-700">{listing.description}</p>
          </div>
        </Card>
      ))
    }
  </div>
</Layout>
