---
import Layout from '~/layouts/Layout.astro'
import { type Listing, ListingSchema } from '~/schemas/listing'
import { Button, Container, Heading } from '@rr/ui/components'
import EmailVerificationWarning from '~/components/EmailVerificationWarning/EmailVerificationWarning.astro'
import { useTranslations } from '~/i18n/ui'
import ListingList from '~/components/ListingList.astro'
import BackgroundRect from '~/components/BackgroundRect.astro'

export const prerender = false

const t = useTranslations()

const items = await Astro.locals.pb
  .collection('listings')
  .getFullList({ expand: 'user,team', filter: 'status = "open" || status = "reserved"' })
const listings = ListingSchema.array().parse(items) as Listing[]

const isNewUser = !Astro.locals.pb.authStore.record!.roles.includes('user');
---

<Layout>
  <Container size="xl" class="relative">
    {!isNewUser && <BackgroundRect variant="page" color="purple" class="h-[55%]! animate-delay-300" />}
    <EmailVerificationWarning class="animate-slide-in" />
    <div class="flex justify-between items-center flex-wrap gap-4 mb-12 animate-slide-in">
      <Heading tag="h1" size="xl">
        {t('dashboard.title')}
      </Heading>
      {!isNewUser && <Button label={t('dashboard.new-listing')} href="/listings/new" />}
    </div>
    {
      isNewUser
        ? (
            <div class="animate-slide-in animate-delay-150">
              <h2 class="text-xl font-bold mb-3">
                {t('dashboard.user-approval.title')}
              </h2>
              <p>{t('dashboard.user-approval.text')}</p>
            </div>
          )
        : (
            <ListingList listings={listings} class="animate-slide-in animate-delay-150" />
          )
    }
  </Container>
</Layout>
