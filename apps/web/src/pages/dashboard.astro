---
import Layout from "~/layouts/Layout.astro";
import { type Listing, ListingSchema } from "~/schemas/listing";
import { Card, Button } from "@rr/ui/components";
import EmailVerificationWarning from "~/components/EmailVerificationWarning/EmailVerificationWarning.astro";

export const prerender = false;

const items = await Astro.locals.pb.collection("listings").getFullList();
const listings = ListingSchema.array().parse(items) as Listing[];
---

<Layout>
  <EmailVerificationWarning />
  <h1 class="text-2xl font-bold mb-4">Dashboard</h1>
  <div class="grid grid-cols-3 gap-4">
    {
      listings.map((listing) => (
        <Card title={listing.title} content={listing.description} border />
      ))
    }
  </div>
</Layout>
